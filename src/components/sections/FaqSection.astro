---
import { faqGroups } from "@/config/faq";
---

<section id="faq" data-nav-theme="light" class="w-full py-24 bg-white scroll-mt-16 lg:scroll-mt-20">
  <div
    class="container px-6 md:px-12 lg:px-24 mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16"
  >
    <div class="lg:col-span-1 space-y-6">
      <span class="text-xs font-bold text-primary uppercase tracking-[0.25em]"
        >Dúvidas</span
      >
      <h2 class="font-serif text-4xl text-stone-900">Perguntas Frequentes</h2>
      <p class="text-stone-600">
        Respostas diretas para as dúvidas mais comuns antes do primeiro
        atendimento.
      </p>
    </div>

    <div class="lg:col-span-2 space-y-8">
      {
        faqGroups.map((group, groupIndex) => (
          <div class="border border-stone-200 bg-stone-50/40">
            <div class="border-b border-stone-200 px-6 py-4">
              <span class="text-[10px] font-bold uppercase tracking-[0.24em] text-primary">
                {String(groupIndex + 1).padStart(2, "0")} · {group.title}
              </span>
            </div>
            <div>
              {group.items.map((item, itemIndex) => (
                <details
                  class="border-b border-stone-200 last:border-b-0 group"
                  name={`faq-${groupIndex}`}
                >
                  <summary class="flex items-center justify-between cursor-pointer px-6 py-6 font-serif text-xl text-stone-800 hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                    <span class="pr-4">{item.question}</span>
                    <svg
                      class="chevron w-4 h-4 shrink-0 text-stone-400 transition-transform duration-200"
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </summary>
                  <div class="px-6 pb-6 text-stone-600 font-sans text-base leading-relaxed">
                    {item.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  details[open] .chevron {
    transform: rotate(180deg);
  }
</style>
