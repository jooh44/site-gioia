---
import { homeConfig } from "@/config/home";
import { siteConfig } from "@/config/site";
import { WhatsAppIcon } from "@/components/ui/whatsapp-icon";
---

<section
  data-nav-theme="dark"
  class="hero-section relative w-full min-h-[100svh] flex flex-col bg-primary text-primary-foreground overflow-hidden"
>
  <!-- Subtle Gradient Overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/30 pointer-events-none z-0"
  >
  </div>

  <!-- Background Decorative SVG Watermark -->
  <div
    class="hidden md:block absolute top-[40%] lg:top-[50%] right-[-10%] lg:right-[-4%] -translate-y-[45%] lg:-translate-y-1/2 w-[80%] lg:w-[54%] xl:w-[50%] h-auto opacity-[0.14] lg:opacity-[0.18] xl:opacity-[0.22] pointer-events-none z-[1]"
  >
    <img
      src="/simbolo-gioia.svg"
      alt=""
      width="1200"
      height="1200"
      class="w-full h-full object-contain"
    />
  </div>

  <!-- Background Graphics (Discrete Symbol Texture) -->
  <div
    class="hidden md:block absolute -left-[10%] lg:-left-[5%] top-[50%] lg:top-[80%] -translate-y-1/2 opacity-[0.12] lg:opacity-[0.16] pointer-events-none z-[1]"
  >
    <img
      src="/simbolo-gioia.svg"
      alt=""
      width="500"
      height="500"
      class="w-[180px] lg:w-[450px] h-auto"
    />
  </div>

  <!-- Mobile Background Cleanup -->
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 h-[44%] md:hidden bg-[radial-gradient(ellipse_at_bottom,rgba(209,175,102,0.14)_0%,rgba(209,175,102,0.04)_28%,transparent_72%)] pointer-events-none z-0"
  >
  </div>

  <!-- Content Wrapper -->
  <div
    class="hero-shell relative z-10 w-full container mx-auto flex flex-col lg:flex-row items-center lg:items-end px-3 sm:px-5 md:px-10 lg:px-14 xl:px-24 flex-1 pt-20 sm:pt-22 md:pt-28 lg:pt-28 xl:pt-32"
  >
    <!-- Left Column: Text Content -->
    <div
      class="hero-copy w-full lg:w-[49%] xl:w-[52%] flex flex-col items-center text-center lg:items-start lg:text-left gap-3 sm:gap-4 md:gap-5 lg:gap-5 xl:gap-6 lg:justify-center lg:self-center pb-0 md:pb-6 lg:pb-8 xl:pb-10 z-20"
    >
      <!-- Main Headline (max 3 lines) -->
      <h1
        class="hero-title font-serif text-[2.7rem] sm:text-[3rem] md:text-[3.35rem] lg:text-[clamp(3.1rem,4.15vw,4.15rem)] xl:text-[clamp(3.45rem,4.5vw,4.75rem)] 2xl:text-[4.95rem] leading-[0.9] sm:leading-[0.94] lg:leading-[0.9] tracking-tight text-white drop-shadow-sm w-full max-w-[12.5ch] sm:max-w-[12.5ch] lg:max-w-[10.8ch] xl:max-w-[11.4ch]"
      >
        <span class="block">Três décadas</span>
        <span class="block whitespace-nowrap">de história na defesa</span>
        <span class="block whitespace-nowrap text-secondary font-light">dos seus direitos.</span>
      </h1>

      <!-- Subtitle -->
      <p
        class="hero-subtitle font-sans text-[1.02rem] sm:text-[1.08rem] md:text-base lg:text-[1.06rem] xl:text-[1.14rem] text-stone-200 font-light leading-[1.65] max-w-[24rem] sm:max-w-[30rem] lg:max-w-[34rem] xl:max-w-[38rem]"
      >
        {homeConfig.hero.subtitle}
      </p>

      <!-- Desktop CTAs -->
      <div class="hero-actions hidden lg:flex flex-col sm:flex-row gap-2.5 sm:gap-3 pt-2 w-full sm:w-auto">
        <a
          href={siteConfig.links.whatsapp}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-secondary text-secondary-foreground hover:bg-[#e1c483] hover:text-primary hover:shadow-[0_0_34px_rgba(209,175,102,0.28)] transition-all duration-300 h-12 xl:h-13 w-full sm:w-auto lg:px-6 xl:px-8 text-[0.76rem] xl:text-[0.82rem] uppercase tracking-[0.16em] xl:tracking-[0.18em] font-bold rounded-none shadow-lg"
        >
          {homeConfig.hero.cta}
          <svg viewBox="0 0 24 24" aria-hidden="true" class="size-[1.05rem] opacity-80" fill="currentColor">
            <path d="M19.05 4.94A9.86 9.86 0 0 0 12.02 2a9.94 9.94 0 0 0-8.6 14.9L2 22l5.25-1.37A9.94 9.94 0 0 0 12.01 22 10 10 0 0 0 22 12.02a9.84 9.84 0 0 0-2.95-7.08Zm-7.03 15.4a8.2 8.2 0 0 1-4.17-1.14l-.3-.18-3.12.82.83-3.04-.2-.31a8.22 8.22 0 1 1 6.96 3.85Zm4.5-6.14c-.25-.13-1.47-.73-1.7-.81-.23-.08-.4-.13-.57.12-.17.25-.66.81-.81.98-.15.17-.3.19-.55.06-.25-.13-1.07-.39-2.03-1.23-.75-.67-1.25-1.48-1.4-1.73-.15-.25-.02-.38.11-.5.11-.11.25-.3.38-.45.13-.15.17-.25.25-.42.08-.17.04-.31-.02-.44-.06-.13-.57-1.38-.78-1.89-.21-.5-.42-.43-.57-.44h-.49c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1s.9 2.44 1.02 2.61c.13.17 1.78 2.72 4.31 3.81.6.26 1.08.41 1.45.52.61.19 1.16.16 1.6.1.49-.07 1.47-.6 1.68-1.19.21-.58.21-1.08.15-1.19-.06-.1-.23-.17-.48-.29Z" />
          </svg>
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center text-white hover:bg-secondary/15 hover:text-secondary h-12 xl:h-13 w-full sm:w-auto lg:px-6 xl:px-8 text-[0.76rem] xl:text-[0.82rem] uppercase tracking-[0.16em] xl:tracking-[0.18em] font-bold rounded-none border border-white/30 hover:border-secondary/70 transition-all"
        >
          Ver Serviços
        </a>
      </div>
    </div>

    <!-- Right Column: Hero Image -->
    <div
      class="hero-art w-full lg:w-[53%] xl:w-[48%] flex justify-center items-end z-10 pointer-events-none relative h-[45vh] sm:h-[50vh] md:h-[54vh] lg:h-[76vh] xl:h-[88vh] mt-6 sm:mt-4 md:mt-6 lg:mt-0 lg:shrink-0"
    >
      <div
        class="hero-figure relative w-full max-w-[430px] sm:max-w-[470px] md:max-w-[520px] lg:max-w-[520px] xl:max-w-[660px] 2xl:max-w-[760px] h-full"
      >
        <div
          aria-hidden="true"
          class="absolute inset-x-[16%] bottom-[4%] h-[14%] bg-[radial-gradient(ellipse_at_center,rgba(0,0,0,0.22)_0%,rgba(0,0,0,0.12)_42%,transparent_78%)] blur-xl"
        >
        </div>
        <div
          aria-hidden="true"
          class="absolute inset-x-[10%] top-[10%] h-[78%] bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.09)_0%,rgba(255,255,255,0.05)_28%,rgba(255,255,255,0.02)_46%,transparent_70%)] blur-3xl"
        >
        </div>
        <img
          src="/gioia-hero-2.webp"
          alt="Pai e filha sorrindo, representando a proteção da família e dignidade"
          width="800"
          height="1000"
          class="hero-portrait relative z-10 w-full h-full object-contain object-bottom scale-[1.08] sm:scale-[1.04] md:scale-100 lg:scale-[0.97] xl:scale-100 drop-shadow-[0_12px_18px_rgba(0,0,0,0.18)]"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>

    <!-- Mobile CTAs -->
    <div class="hero-actions-mobile flex lg:hidden flex-col gap-2.5 w-full mt-6 px-1 pb-4 z-20">
      <a
        href={siteConfig.links.whatsapp}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-secondary text-secondary-foreground hover:bg-[#e1c483] hover:text-primary hover:shadow-[0_0_34px_rgba(209,175,102,0.28)] transition-all duration-300 h-13 w-full text-[0.82rem] uppercase tracking-[0.18em] font-bold rounded-none shadow-lg"
      >
        {homeConfig.hero.cta}
        <svg viewBox="0 0 24 24" aria-hidden="true" class="size-[1.05rem] opacity-80" fill="currentColor">
          <path d="M19.05 4.94A9.86 9.86 0 0 0 12.02 2a9.94 9.94 0 0 0-8.6 14.9L2 22l5.25-1.37A9.94 9.94 0 0 0 12.01 22 10 10 0 0 0 22 12.02a9.84 9.84 0 0 0-2.95-7.08Zm-7.03 15.4a8.2 8.2 0 0 1-4.17-1.14l-.3-.18-3.12.82.83-3.04-.2-.31a8.22 8.22 0 1 1 6.96 3.85Zm4.5-6.14c-.25-.13-1.47-.73-1.7-.81-.23-.08-.4-.13-.57.12-.17.25-.66.81-.81.98-.15.17-.3.19-.55.06-.25-.13-1.07-.39-2.03-1.23-.75-.67-1.25-1.48-1.4-1.73-.15-.25-.02-.38.11-.5.11-.11.25-.3.38-.45.13-.15.17-.25.25-.42.08-.17.04-.31-.02-.44-.06-.13-.57-1.38-.78-1.89-.21-.5-.42-.43-.57-.44h-.49c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1s.9 2.44 1.02 2.61c.13.17 1.78 2.72 4.31 3.81.6.26 1.08.41 1.45.52.61.19 1.16.16 1.6.1.49-.07 1.47-.6 1.68-1.19.21-.58.21-1.08.15-1.19-.06-.1-.23-.17-.48-.29Z" />
        </svg>
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center text-white hover:bg-secondary/15 hover:text-secondary h-13 w-full text-[0.82rem] uppercase tracking-[0.18em] font-bold rounded-none border border-white/30 hover:border-secondary/70 transition-all"
      >
        Ver Serviços
      </a>
    </div>
  </div>
</section>
