---
import { aboutConfig } from "@/config/about";
---

<section
  id="about"
  data-nav-theme="dark"
  class="w-full py-16 md:py-24 lg:py-32 bg-primary text-white relative overflow-hidden scroll-mt-16 lg:scroll-mt-20"
>
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none z-0 bg-[url('/images/bg.webp')] bg-cover bg-center md:bg-fixed opacity-24 scale-105"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-r from-primary/88 via-primary/68 to-primary/42 pointer-events-none z-0"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-b from-primary/52 via-primary/28 to-black/48 pointer-events-none z-0"
  >
  </div>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_right_center,rgba(209,175,102,0.06),transparent_28%)] pointer-events-none z-0"
  >
  </div>

  <div class="container px-6 md:px-12 lg:px-24 mx-auto relative z-10">
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start"
    >
      <div class="lg:col-span-5 space-y-8 lg:space-y-10 lg:sticky lg:top-24">
        <div class="space-y-4">
          <span
            class="text-xs font-bold text-secondary uppercase tracking-[0.25em] block"
          >
            {aboutConfig.eyebrow}
          </span>
          <h2
            class="font-serif text-3xl md:text-4xl lg:text-5xl text-white leading-tight"
          >
            {aboutConfig.title}
          </h2>
        </div>
        <div
          class="space-y-4 text-stone-300 font-sans text-base lg:text-lg leading-relaxed"
        >
          <p>{aboutConfig.intro}</p>
          <p class="hidden md:block">{aboutConfig.approach}</p>
          <p class="text-white font-medium">{aboutConfig.closing}</p>
        </div>
      </div>

      <div class="lg:col-span-7 space-y-4">
        <div
          class="relative overflow-hidden border border-secondary/20 bg-[linear-gradient(180deg,rgba(255,255,255,0.04)_0%,rgba(255,255,255,0.02)_100%)] min-h-[22rem] md:min-h-[28rem] lg:min-h-[34rem]"
        >
          <img
            src="/about-gioia-team.webp"
            alt="Equipe Gioia e Associados em retrato institucional"
            class="w-full h-full object-cover object-top absolute inset-0"
            loading="lazy"
          />
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-secondary/12 border border-secondary/18"
        >
          <div
            class="bg-primary/55 px-6 py-5 md:px-6 md:py-6 flex flex-col items-start gap-4 border-b sm:border-b-0 border-secondary/12"
          >
            <!-- Scale icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-secondary/80 shrink-0 size-5"
            >
              <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"
              ></path>
              <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"
              ></path>
              <path d="M7 21h10"></path>
              <path d="M12 3v18"></path>
              <path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"></path>
            </svg>
            <div>
              <span
                class="text-[11px] font-bold uppercase tracking-[0.22em] text-secondary/85"
                >{aboutConfig.mission.title}</span
              >
              <p class="text-sm md:text-[0.95rem] text-stone-300 leading-relaxed mt-1.5 max-w-[24ch]">
                {aboutConfig.mission.description}
              </p>
            </div>
          </div>
          <div
            class="bg-primary/55 px-6 py-5 md:px-6 md:py-6 flex flex-col items-start gap-4 border-b sm:border-b-0 border-secondary/12"
          >
            <!-- Telescope icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-secondary/80 shrink-0 size-5"
            >
              <path d="m10.065 12.493-6.18 1.318a.934.934 0 0 1-1.108-.702l-.537-2.15a1.07 1.07 0 0 1 .691-1.265l13.504-4.44"></path>
              <path d="m13.56 11.747 4.332-.924"></path>
              <path d="m16 21-3.105-6.21"></path>
              <path d="M16.485 5.94a2 2 0 0 1 1.455-2.425l1.09-.272a1 1 0 0 1 1.212.727l1.515 6.06a1 1 0 0 1-.727 1.213l-1.09.272a2 2 0 0 1-2.425-1.455z"></path>
              <path d="m6.158 8.633 1.114 4.456"></path>
              <path d="m8 21 3.105-6.21"></path>
            </svg>
            <div>
              <span
                class="text-[11px] font-bold uppercase tracking-[0.22em] text-secondary/85"
                >{aboutConfig.vision.title}</span
              >
              <p class="text-sm md:text-[0.95rem] text-stone-300 leading-relaxed mt-1.5 max-w-[24ch]">
                {aboutConfig.vision.description}
              </p>
            </div>
          </div>
          <div class="bg-primary/55 px-6 py-5 md:px-6 md:py-6 flex flex-col items-start gap-4">
            <!-- Gem icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-secondary/80 shrink-0 size-5"
            >
              <path d="M6 3h12l4 6-10 13L2 9Z"></path>
              <path d="M11 3 8 9l4 13 4-13-3-6"></path>
              <path d="M2 9h20"></path>
            </svg>
            <div>
              <span
                class="text-[11px] font-bold uppercase tracking-[0.22em] text-secondary/85"
                >Valores</span
              >
              <p class="text-sm md:text-[0.95rem] text-stone-300 leading-relaxed mt-1.5 max-w-[24ch]">
                Ética, resultado, atendimento humano e disciplina operacional em cada entrega.
              </p>
              <div class="flex flex-wrap gap-2 mt-3">
                {aboutConfig.values.slice(0, 4).map((value) => (
                  <span class="border border-secondary/20 bg-white/4 px-2.5 py-1 text-[10px] uppercase tracking-[0.18em] text-secondary/90">
                    {value.title}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
