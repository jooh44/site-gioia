---
import { siteConfig } from "@/config/site";
---

<section
  data-nav-theme="dark"
  class="w-full py-24 md:py-32 bg-primary text-white relative overflow-hidden"
>
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/30 pointer-events-none"
  >
  </div>
  <div class="site-shell relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
    <div class="space-y-10">
      <h2
        class="font-serif text-3xl md:text-5xl lg:text-6xl text-white leading-tight"
      >
        Vamos lutar pelo <br /><span class="text-secondary">seu direito?</span>
      </h2>
      <p
        class="text-stone-200 text-xl font-light leading-relaxed max-w-lg"
      >
        Não deixe para depois o que pode ser irreversível. Nossa equipe está
        pronta para ouvir sua história e traçar a melhor estratégia.
      </p>
      <div class="flex flex-col sm:flex-row gap-6">
        <a
          href={siteConfig.links.whatsapp}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-secondary text-secondary-foreground hover:bg-[#e1c483] hover:text-primary hover:shadow-[0_0_34px_rgba(209,175,102,0.28)] h-16 px-10 text-sm uppercase tracking-[0.25em] font-medium rounded-none shadow-lg w-full sm:w-auto"
        >
          Falar no WhatsApp
          <svg viewBox="0 0 24 24" aria-hidden="true" class="size-[1.05rem] opacity-80" fill="currentColor">
            <path d="M19.05 4.94A9.86 9.86 0 0 0 12.02 2a9.94 9.94 0 0 0-8.6 14.9L2 22l5.25-1.37A9.94 9.94 0 0 0 12.01 22 10 10 0 0 0 22 12.02a9.84 9.84 0 0 0-2.95-7.08Zm-7.03 15.4a8.2 8.2 0 0 1-4.17-1.14l-.3-.18-3.12.82.83-3.04-.2-.31a8.22 8.22 0 1 1 6.96 3.85Zm4.5-6.14c-.25-.13-1.47-.73-1.7-.81-.23-.08-.4-.13-.57.12-.17.25-.66.81-.81.98-.15.17-.3.19-.55.06-.25-.13-1.07-.39-2.03-1.23-.75-.67-1.25-1.48-1.4-1.73-.15-.25-.02-.38.11-.5.11-.11.25-.3.38-.45.13-.15.17-.25.25-.42.08-.17.04-.31-.02-.44-.06-.13-.57-1.38-.78-1.89-.21-.5-.42-.43-.57-.44h-.49c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1s.9 2.44 1.02 2.61c.13.17 1.78 2.72 4.31 3.81.6.26 1.08.41 1.45.52.61.19 1.16.16 1.6.1.49-.07 1.47-.6 1.68-1.19.21-.58.21-1.08.15-1.19-.06-.1-.23-.17-.48-.29Z" />
          </svg>
        </a>
        <a
          href={`tel:${siteConfig.contact.phone.replace(/\D/g, "")}`}
          class="inline-flex items-center justify-center bg-transparent border border-white/20 text-white hover:bg-white hover:text-primary h-16 px-10 text-sm uppercase tracking-[0.25em] font-medium rounded-none w-full sm:w-auto transition-all"
        >
          Ligar Agora
        </a>
      </div>

      <div
        class="pt-12 space-y-4 border-t border-white/10 mt-12 text-stone-300 font-sans text-sm"
      >
        <p class="flex items-center gap-3">
          <span
            class="text-secondary font-bold uppercase tracking-widest text-[10px]"
            >Endereço:</span
          >
          Rua Barão de Jundiaí, 523 – Lapa, São Paulo – SP
        </p>
        <p class="flex items-center gap-3">
          <span
            class="text-secondary font-bold uppercase tracking-widest text-[10px]"
            >Telefone:</span
          >
          (11) 3835-3200
        </p>
        <p class="flex items-center gap-3">
          <span
            class="text-secondary font-bold uppercase tracking-widest text-[10px]"
            >E-mail:</span
          >
          {siteConfig.contact.email}
        </p>
      </div>
    </div>

    <div
      class="relative border-l border-white/10 pl-12 py-8 hidden lg:block"
    >
      <blockquote
        class="font-serif text-2xl leading-relaxed text-white/80 italic"
      >
        &quot;A verdadeira justiça é aquela que restaura a dignidade, protege a
        vida e não se curva diante da injustiça.&quot;
      </blockquote>
      <cite
        class="block font-sans text-xs uppercase tracking-[0.2em] text-secondary not-italic mt-6"
      >
        Princípio Gioia
      </cite>
    </div>
  </div>
</section>
