---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Blog | Gioia e Associados Advocacia"
  description="Artigos e atualizações jurídicas da Gioia e Associados Advocacia."
  canonical="https://gioiaeassociados.com.br/blog"
  robots="noindex, nofollow"
>
  <div
    class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4"
  >
    <h1
      class="text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl lg:text-6xl text-stone-900 mb-4"
    >
      Em Breve
    </h1>
    <p class="text-stone-500 max-w-[600px] text-lg">
      Nossos artigos e atualizações jurídicas estarão disponíveis aqui em breve.
    </p>
  </div>
</BaseLayout>
