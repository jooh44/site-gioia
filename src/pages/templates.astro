</style>

<script>
  const app = document.querySelector("[data-template-app]");
  const choices = Array.from(document.querySelectorAll("[data-template-target]"));
  const templates = Array.from(document.querySelectorAll("[data-template]"));
  const printButton = document.querySelector("[data-print-document]");
  const resetButton = document.querySelector("[data-reset-template]");
  const undoButton = document.querySelector("[data-undo-change]");
  const reviewButton = document.querySelector("[data-review-pending]");
  const openInsertMenuButton = document.querySelector("[data-open-insert-menu]");
  const insertMenu = document.querySelector("[data-insert-menu]");
  const insertButtons = Array.from(document.querySelectorAll("[data-insert-block]"));
  const status = document.querySelector("[data-editor-status]");
  const fieldList = document.querySelector("[data-field-list]");
  const progressCount = document.querySelector("[data-progress-count]");
  const progressPending = document.querySelector("[data-progress-pending]");
  const storagePrefix = "gioia-template-editor:";
  const sectionStrategies = {
    peticao: "roman",
    procuracao: "plain",
    contrato: "clause",
  };
  const clauseWords = [
    "Primeira",
    "Segunda",
    "Terceira",
    "Quarta",
    "Quinta",
    "Sexta",
    "Sétima",
    "Oitava",
    "Nona",
    "Décima",
    "Décima Primeira",
    "Décima Segunda",
    "Décima Terceira",
    "Décima Quarta",
    "Décima Quinta",
  ];
  const essentialFields = {
    peticao: [
      { id: "peticao-vara", label: "Vara / Foro / Comarca / Estado", type: "text" },
      { id: "peticao-processo", label: "Número do processo", type: "text" },
      { id: "peticao-autora", label: "Nome da parte autora", type: "text" },
      { id: "peticao-qualificacao", label: "Qualificação da parte autora", type: "textarea", rows: 2 },
      { id: "peticao-acao", label: "Nome da ação", type: "text" },
      { id: "peticao-re", label: "Nome da parte ré", type: "text" },
      { id: "peticao-documento-re", label: "CPF/CNPJ da parte ré", type: "text" },
      { id: "peticao-endereco-re", label: "Endereço da parte ré", type: "textarea", rows: 2 },
      { id: "peticao-fatos", label: "Síntese fática", type: "textarea", rows: 4 },
      { id: "peticao-tutela", label: "Fundamento da tutela", type: "textarea", rows: 4 },
      { id: "peticao-direito", label: "Fundamentação jurídica", type: "textarea", rows: 4 },
      { id: "peticao-obrigacao", label: "Pedido principal", type: "textarea", rows: 3 },
      { id: "peticao-valor", label: "Valor da causa", type: "text" },
      { id: "peticao-data", label: "Data", type: "text" },
    ],
    procuracao: [
      { id: "proc-outorgante", label: "Nome do outorgante", type: "text" },
      { id: "proc-qualificacao", label: "Qualificação", type: "textarea", rows: 2 },
      { id: "proc-rg", label: "RG", type: "text" },
      { id: "proc-cpf", label: "CPF", type: "text" },
      { id: "proc-email", label: "E-mail", type: "text" },
      { id: "proc-endereco", label: "Endereço", type: "textarea", rows: 2 },
      { id: "proc-referencia", label: "Referência do caso", type: "textarea", rows: 2 },
      { id: "proc-data", label: "Data", type: "text" },
    ],
    contrato: [
      { id: "contrato-cliente", label: "Nome do cliente", type: "text" },
      { id: "contrato-qualificacao", label: "Qualificação do cliente", type: "textarea", rows: 2 },
      { id: "contrato-endereco", label: "Endereço", type: "textarea", rows: 2 },
      { id: "contrato-objeto", label: "Objeto", type: "textarea", rows: 3 },
      { id: "contrato-foro", label: "Foro / órgão", type: "text" },
      { id: "contrato-parte-adversa", label: "Parte adversa", type: "text" },
      { id: "contrato-honorarios", label: "Honorários", type: "text" },
      { id: "contrato-quota", label: "Quota litis", type: "textarea", rows: 2 },
      { id: "contrato-rescisao", label: "Cláusula de rescisão", type: "textarea", rows: 3 },
      { id: "contrato-data", label: "Data", type: "text" },
    ],
  };
  const boundFields = new WeakSet();
  const undoStack = [];
  let lastFocusedEditable = null;
  let generatedFieldCount = 0;
  let statusTimeout = 0;

  const getActiveTemplate = () => document.querySelector(".legal-page.is-active");
  const getActiveBody = () => getActiveTemplate()?.querySelector(".document-body");
  const getFieldById = (id) => document.querySelector(`[data-editable-id="${id}"]`);
  const bodyKey = (template) => `${storagePrefix}body:${template.dataset.template}`;
  const fieldKey = (field) => `${storagePrefix}${field.dataset.editableId}`;
  const panelFieldSelector = (id) => `[data-panel-field="${id}"]`;
  const getTemplateLabel = (name) => choices.find((choice) => choice.dataset.templateTarget === name)?.querySelector("span")?.textContent || "documento";
  const sectionPrefixSelector = "[data-section-prefix]";
  const sectionTitleSelector = "[data-section-title]";
  const activeEditableSelector = ".editable-field.is-active-field";
  const panelFieldActiveSelector = "[data-panel-field]";
  const fixedEndAnchors = {
    peticao: ["peticao-valor", "peticao-data"],
    procuracao: ["proc-data"],
    contrato: ["contrato-data"],
  };

  const intToRoman = (value) => {
    const map = [
      [1000, "M"], [900, "CM"], [500, "D"], [400, "CD"], [100, "C"], [90, "XC"],
      [50, "L"], [40, "XL"], [10, "X"], [9, "IX"], [5, "V"], [4, "IV"], [1, "I"],
    ];
    let remainder = value;
    let result = "";
    map.forEach(([arabic, roman]) => {
      while (remainder >= arabic) {
        result += roman;
        remainder -= arabic;
      }
    });
    return result;
  };

  const getClauseWord = (index) => clauseWords[index - 1] || `${index}ª`;
  const getSectionPrefix = (templateName, index) => {
    const strategy = sectionStrategies[templateName];
    if (strategy === "roman") return `${intToRoman(index)}.`;
    if (strategy === "clause") return `Cláusula ${getClauseWord(index)} —`;
    return "";
  };

  const setStatus = (message, idleMessage = "Rascunho salvo neste navegador") => {
    if (!status) return;
    status.textContent = message;
    window.clearTimeout(statusTimeout);
    statusTimeout = window.setTimeout(() => {
      status.textContent = idleMessage;
    }, 1600);
  };

  const closeInsertMenu = () => {
    if (!insertMenu || !openInsertMenuButton) return;
    insertMenu.hidden = true;
    openInsertMenuButton.setAttribute("aria-expanded", "false");
  };

  const clearDocumentSelectionState = () => {
    document.querySelectorAll(".is-active-field").forEach((node) => node.classList.remove("is-active-field"));
    document.querySelectorAll(".is-linked-field").forEach((node) => node.classList.remove("is-linked-field"));
    document.querySelectorAll(".is-selected-block").forEach((node) => node.classList.remove("is-selected-block"));
  };

  const openInsertMenu = () => {
    if (!insertMenu || !openInsertMenuButton) return;
    insertMenu.hidden = false;
    openInsertMenuButton.setAttribute("aria-expanded", "true");
  };

  const toggleInsertMenu = () => {
    if (!insertMenu || !openInsertMenuButton) return;
    if (insertMenu.hidden) {
      openInsertMenu();
      return;
    }
    closeInsertMenu();
  };

  const updateUndoButton = () => {
    if (!undoButton) return;
    undoButton.disabled = undoStack.length === 0;
  };

  const getFieldDisplayValue = (field) => {
    if (!field) return "";
    const placeholder = field.dataset.placeholder || "";
    const value = field.textContent.trim();
    return value === placeholder.trim() ? "" : value;
  };

  const snapshotActiveBody = () => {
    const activeTemplate = getActiveTemplate();
    const body = activeTemplate?.querySelector(".document-body");
    if (!activeTemplate || !body) return;

    const bodyClone = body.cloneNode(true);
    bodyClone.querySelectorAll(".block-delete").forEach((button) => button.remove());
    undoStack.push({
      template: activeTemplate.dataset.template,
      html: bodyClone.innerHTML,
    });
    if (undoStack.length > 20) undoStack.shift();
    updateUndoButton();
  };

  // Structural undo only: block insertion/removal snapshots the full body state.
  const snapshotStructuralChange = () => {
    snapshotActiveBody();
  };

  const placeCaretInside = (field) => {
    const selection = window.getSelection();
    const range = document.createRange();
    range.selectNodeContents(field);
    range.collapse(false);
    selection?.removeAllRanges();
    selection?.addRange(range);
  };

  const fieldHasPlaceholder = (field, placeholder) => field.innerHTML.trim() === placeholder.trim();
  const syncEmptyState = (field) => {
    field.classList.toggle("is-empty", !field.textContent.trim());
  };

  const clearPlaceholder = (field, placeholder) => {
    if (!fieldHasPlaceholder(field, placeholder)) return false;
    field.innerHTML = "";
    syncEmptyState(field);
    requestAnimationFrame(() => placeCaretInside(field));
    return true;
  };

  const persistEditableValue = (field, placeholder, { restoreOnEmpty = true } = {}) => {
    if (!field.textContent.trim()) {
      window.localStorage.removeItem(fieldKey(field));
      if (restoreOnEmpty) {
        field.innerHTML = field.dataset.placeholder || placeholder;
      } else {
        field.innerHTML = "";
      }
      syncEmptyState(field);
      syncPanelValue(field);
      saveActiveBody();
      return;
    }

    window.localStorage.setItem(fieldKey(field), field.innerHTML);
    syncEmptyState(field);
    syncPanelValue(field);
    if (field.closest("h3")) renumberSections(field.closest(".legal-page")?.dataset.template || getActiveTemplate()?.dataset.template);
    saveActiveBody();
  };

  const syncPanelValue = (field) => {
    if (!field?.dataset.editableId) return;
    const control = document.querySelector(panelFieldSelector(field.dataset.editableId));
    if (!control) return;
    const value = getFieldDisplayValue(field);
    if (control.value !== value) control.value = value;
  };

  const highlightPanelCard = (fieldId) => {
    fieldList?.querySelectorAll(".field-card").forEach((card) => {
      card.classList.toggle("is-active", card.dataset.fieldCard === fieldId);
    });
  };

  const refreshPendingState = () => {
    const template = getActiveTemplate();
    const configs = essentialFields[template?.dataset.template] || [];
    const filled = configs.filter(({ id }) => getFieldDisplayValue(getFieldById(id))).length;
    const pending = configs.length - filled;

    if (progressCount) {
      progressCount.textContent = `${filled} de ${configs.length} campos preenchidos`;
    }
    if (progressPending) {
      progressPending.textContent = pending > 0
        ? `${pending} pendência${pending > 1 ? "s" : ""} nos campos essenciais`
        : "Campos essenciais completos";
    }

    fieldList?.querySelectorAll(".field-card").forEach((card) => {
      const field = getFieldById(card.dataset.fieldCard);
      card.classList.toggle("is-pending", !getFieldDisplayValue(field));
    });
  };

  const saveActiveBody = (message = "Rascunho salvo") => {
    const activeTemplate = getActiveTemplate();
    const body = activeTemplate?.querySelector(".document-body");
    if (!activeTemplate || !body) return false;
    const bodyClone = body.cloneNode(true);
    bodyClone.querySelectorAll(".block-delete").forEach((button) => button.remove());
    const key = bodyKey(activeTemplate);
    const nextHtml = bodyClone.innerHTML;
    const currentHtml = window.localStorage.getItem(key);
    refreshPendingState();
    if (currentHtml === nextHtml) return false;
    window.localStorage.setItem(key, nextHtml);
    setStatus(message);
    return true;
  };

  const createEditable = (id, placeholder) => {
    const field = document.createElement("span");
    field.className = "editable-field";
    field.contentEditable = "true";
    field.spellcheck = true;
    field.dataset.editableId = id;
    field.dataset.placeholder = placeholder;
    field.innerHTML = placeholder;
    bindEditable(field);
    return field;
  };

  const bindEditable = (field) => {
    if (boundFields.has(field)) return;
    boundFields.add(field);

    const placeholder = field.dataset.placeholder || field.innerHTML;
    field.dataset.placeholder = placeholder;

    const saved = window.localStorage.getItem(fieldKey(field));
    if (saved) field.innerHTML = saved;
    syncEmptyState(field);

    field.addEventListener("pointerdown", (event) => {
      lastFocusedEditable = field;
      if (fieldHasPlaceholder(field, placeholder)) {
        event.preventDefault();
        field.focus({ preventScroll: true });
        clearPlaceholder(field, placeholder);
      }
    });

    field.addEventListener("focus", () => {
      document.querySelectorAll(".is-active-field").forEach((activeField) => {
        activeField.classList.remove("is-active-field");
      });
      document.querySelectorAll(".is-linked-field").forEach((linkedField) => {
        linkedField.classList.remove("is-linked-field");
      });
      lastFocusedEditable = field;
      field.classList.add("is-active-field");
      field.classList.add("is-linked-field");
      highlightPanelCard(field.dataset.editableId);
      setStatus(`Editando: ${field.dataset.panelLabel || "campo"}`);
    });

    field.addEventListener("beforeinput", (event) => {
      if (!fieldHasPlaceholder(field, placeholder)) return;
      const inputType = event.inputType || "";
      const isInsertion = inputType.startsWith("insert");
      if (!isInsertion) return;

      event.preventDefault();
      const insertedText = event.data
        ?? event.dataTransfer?.getData("text/plain")
        ?? event.clipboardData?.getData("text/plain")
        ?? "";
      field.textContent = insertedText;
      syncEmptyState(field);
      placeCaretInside(field);
      persistEditableValue(field, placeholder);
    });

    field.addEventListener("click", () => {
      const block = field.closest("p, h3, ol, .signature-grid");
      document.querySelectorAll(".is-selected-block").forEach((selected) => selected.classList.remove("is-selected-block"));
      block?.classList.add("is-selected-block");
    });

    field.addEventListener("input", () => {
      persistEditableValue(field, placeholder, { restoreOnEmpty: false });
    });

    field.addEventListener("blur", () => {
      field.classList.remove("is-active-field");
      field.classList.remove("is-linked-field");
      persistEditableValue(field, placeholder);
    });
  };

  const createStructuredHeading = (templateName, title, index, idBase) => {
    const heading = document.createElement("h3");
    heading.className = "section-heading-block";
    heading.dataset.blockType = "section";
    heading.dataset.sectionLevel = "1";

    const prefix = document.createElement("span");
    prefix.dataset.sectionPrefix = "";
    prefix.className = "section-prefix";
    prefix.textContent = getSectionPrefix(templateName, index);

    const titleField = createEditable(`${idBase}-titulo`, "[NOVA SEÇÃO]");
    titleField.dataset.panelLabel = "Título da seção";
    titleField.dataset.sectionTitle = "";
    titleField.textContent = title;

    heading.append(prefix, titleField);
    return heading;
  };

  const parseInitialHeading = (templateName, text) => {
    if (templateName === "peticao") {
      const match = text.match(/^[IVXLCDM]+\.\s*(.+)$/i);
      return match ? match[1] : null;
    }
    if (templateName === "contrato") {
      const match = text.match(/^Cláusula\s+.+?\s+—\s+(.+)$/i);
      return match ? match[1] : null;
    }
    return null;
  };

  const normalizeTemplateSections = (template) => {
    const body = template?.querySelector(".document-body");
    if (!body) return;
    const templateName = template.dataset.template;
    const strategy = sectionStrategies[templateName];
    if (strategy === "plain") return;

    const headings = Array.from(body.querySelectorAll(":scope > h3"));
    headings.forEach((heading) => {
      if (heading.querySelector(sectionPrefixSelector) && heading.querySelector(sectionTitleSelector)) return;

      const rawText = heading.textContent.trim();
      const title = parseInitialHeading(templateName, rawText);
      if (!title) return;
      const idBase = `normalized-${templateName}-${Math.random().toString(36).slice(2, 8)}`;
      heading.innerHTML = "";
      heading.dataset.blockType = "section";
      heading.dataset.sectionLevel = "1";

      const prefix = document.createElement("span");
      prefix.dataset.sectionPrefix = "";
      prefix.className = "section-prefix";

      const titleField = createEditable(`${idBase}-titulo`, "[NOVA SEÇÃO]");
      titleField.dataset.sectionTitle = "";
      titleField.dataset.panelLabel = "Título da seção";
      titleField.textContent = title;

      heading.append(prefix, titleField);
    });

    renumberSections(templateName);
  };

  const renumberSections = (templateName) => {
    const template = document.querySelector(`[data-template="${templateName}"]`);
    const body = template?.querySelector(".document-body");
    if (!body) return;
    const strategy = sectionStrategies[templateName];
    if (strategy === "plain") return;

    const headings = Array.from(body.querySelectorAll(':scope > h3[data-block-type="section"]'));
    headings.forEach((heading, index) => {
      heading.dataset.sectionIndex = String(index + 1);
      const prefix = heading.querySelector(sectionPrefixSelector);
      if (prefix) prefix.textContent = getSectionPrefix(templateName, index + 1);
      const titleField = heading.querySelector(sectionTitleSelector);
      if (titleField) {
        titleField.dataset.panelLabel = `${getTemplateLabel(templateName)} · título da seção ${index + 1}`;
      }
    });
  };

  const renderFieldPanel = (templateName) => {
    if (!fieldList) return;
    const fields = essentialFields[templateName] || [];
    fieldList.innerHTML = "";

    fields.forEach((config) => {
      const card = document.createElement("div");
      card.className = "field-card";
      card.dataset.fieldCard = config.id;

      const meta = document.createElement("div");
      meta.className = "field-meta";

      const label = document.createElement("label");
      label.htmlFor = `panel-${config.id}`;
      label.textContent = config.label;

      meta.append(label);

      const control = document.createElement(config.type === "textarea" ? "textarea" : "input");
      control.id = `panel-${config.id}`;
      control.dataset.panelField = config.id;
      if (config.type !== "textarea") control.type = "text";
      if (config.rows) control.rows = config.rows;
      control.placeholder = "Preencha aqui";

      const field = getFieldById(config.id);
      if (field) {
        field.dataset.panelLabel = config.label;
        control.value = getFieldDisplayValue(field);
      }

      control.addEventListener("focus", () => {
        const targetField = getFieldById(config.id);
        highlightPanelCard(config.id);
        targetField?.scrollIntoView({ block: "center", behavior: "smooth" });
        targetField?.classList.add("is-linked-field");
      });

      control.addEventListener("input", () => {
        const targetField = getFieldById(config.id);
        if (!targetField) return;
        const value = control.value.trim();
        if (value) {
          targetField.textContent = control.value;
          window.localStorage.setItem(fieldKey(targetField), targetField.innerHTML);
        } else {
          targetField.textContent = targetField.dataset.placeholder || "";
          window.localStorage.removeItem(fieldKey(targetField));
        }
        syncEmptyState(targetField);
        saveActiveBody();
      });

      control.addEventListener("blur", () => {
        getFieldById(config.id)?.classList.remove("is-linked-field");
      });

      card.append(meta, control);
      fieldList.append(card);
    });

    refreshPendingState();
  };

  const setTemplate = (name) => {
    choices.forEach((choice) => {
      choice.classList.toggle("is-active", choice.dataset.templateTarget === name);
    });
    templates.forEach((template) => {
      template.classList.toggle("is-active", template.dataset.template === name);
    });
    window.localStorage.setItem(`${storagePrefix}active`, name);
    renderFieldPanel(name);
    refreshPendingState();
  };

  const restoreBody = (snapshot) => {
    const template = document.querySelector(`[data-template="${snapshot.template}"]`);
    const body = template?.querySelector(".document-body");
    if (!template || !body) return;

    body.innerHTML = snapshot.html;
    normalizeTemplateSections(template);
    body.querySelectorAll("[data-editable-id]").forEach(bindEditable);
    decorateBlocks(body);
    setTemplate(snapshot.template);
    window.localStorage.setItem(bodyKey(template), template.querySelector(".document-body")?.innerHTML || snapshot.html);
    setStatus("Alteração estrutural desfeita");
  };

  const undoLastChange = () => {
    const snapshot = undoStack.pop();
    updateUndoButton();
    if (!snapshot) {
      setStatus("Nada para desfazer");
      return;
    }
    restoreBody(snapshot);
  };

  const getReferenceBlock = () => {
    const body = getActiveBody();
    if (!body || !lastFocusedEditable || !body.contains(lastFocusedEditable)) return body?.lastElementChild;
    return lastFocusedEditable.closest("p, h3, ol, li") || body.lastElementChild;
  };

  const getFixedEndAnchor = (templateName) => {
    const body = getActiveBody();
    if (!body) return null;
    const anchorIds = fixedEndAnchors[templateName] || [];
    for (const id of anchorIds) {
      const field = body.querySelector(`[data-editable-id="${id}"]`);
      const block = field?.closest("p, h3, ol, li");
      if (block) return block;
    }
    return null;
  };

  const shouldUseReferenceBlock = (reference, endAnchor) => {
    if (!reference || !endAnchor) return Boolean(reference);
    const position = reference.compareDocumentPosition(endAnchor);
    const isBeforeEndAnchor = Boolean(position & Node.DOCUMENT_POSITION_FOLLOWING);
    const isSameNode = reference === endAnchor;
    return isBeforeEndAnchor && !isSameNode;
  };

  const insertAfterReference = (nodes) => {
    const body = getActiveBody();
    const activeTemplate = getActiveTemplate();
    if (!body || !activeTemplate) return;

    const reference = getReferenceBlock();
    const normalizedReference = reference?.tagName === "LI" ? reference.closest("ol") : reference;
    const endAnchor = getFixedEndAnchor(activeTemplate.dataset.template);
    const anchor = shouldUseReferenceBlock(normalizedReference, endAnchor) ? normalizedReference : null;
    const fragment = document.createDocumentFragment();
    nodes.forEach((node) => fragment.append(node));
    body.insertBefore(fragment, anchor?.nextSibling || endAnchor || null);
    nodes[0]?.scrollIntoView({ block: "center", behavior: "smooth" });

    renumberSections(activeTemplate.dataset.template);
    decorateBlocks(body);
    saveActiveBody("Estrutura atualizada");
    nodes[0]?.querySelector("[data-editable-id]")?.focus();
  };

  const insertBlock = (type) => {
    snapshotStructuralChange();
    generatedFieldCount += 1;
    const idBase = `custom-${Date.now()}-${generatedFieldCount}`;
    const templateName = getActiveTemplate()?.dataset.template || "peticao";

    if (type === "field") {
      const field = createEditable(`${idBase}-campo`, "[NOVO CAMPO]");
      const space = document.createTextNode(" ");
      const endAnchor = getFixedEndAnchor(templateName);
      const focusedBlock = lastFocusedEditable?.closest("p, h3, ol, li");
      const inlineAllowed = lastFocusedEditable && getActiveBody()?.contains(lastFocusedEditable) && shouldUseReferenceBlock(focusedBlock, endAnchor);
      if (inlineAllowed) {
        lastFocusedEditable.insertAdjacentText("afterend", " ");
        lastFocusedEditable.after(field);
      } else {
        const paragraph = document.createElement("p");
        paragraph.className = "centered-insert";
        paragraph.append(createEditable(`${idBase}-paragrafo`, "[NOVO CAMPO]"));
        insertAfterReference([paragraph]);
        return;
      }
      field.after(space);
      saveActiveBody("Campo livre adicionado");
      field.focus();
      return;
    }

    if (type === "section") {
      const currentSectionCount = getActiveBody()?.querySelectorAll(":scope > h3").length || 0;
      const heading = createStructuredHeading(
        templateName,
        templateName === "contrato" ? "Nova cláusula" : "Nova seção",
        currentSectionCount + 1,
        idBase,
      );

      const paragraph = document.createElement("p");
      paragraph.append(createEditable(`${idBase}-texto`, "[DESCREVER CONTEÚDO]"));

      insertAfterReference([heading, paragraph]);
      return;
    }

    if (type === "paragraph") {
      const paragraph = document.createElement("p");
      paragraph.append(createEditable(`${idBase}-paragrafo`, "[NOVO PARÁGRAFO]"));
      insertAfterReference([paragraph]);
      return;
    }

    const body = getActiveBody();
    if (!body) return;
    let list = lastFocusedEditable?.closest("ol");
    if (!list || !body.contains(list)) {
      list = body.querySelector("ol") || document.createElement("ol");
      if (!list.parentElement) body.append(list);
    }
    const item = document.createElement("li");
    item.append(createEditable(`${idBase}-item`, "[NOVO ITEM]"));
    list.append(item);
    decorateBlocks(body);
    saveActiveBody("Novo item adicionado");
    item.querySelector("[data-editable-id]")?.focus();
  };

  const removeBlock = (block) => {
    const body = getActiveBody();
    const activeTemplate = getActiveTemplate();
    if (!body || !block || !activeTemplate) return;
    snapshotStructuralChange();

    if (block.tagName === "H3") {
      let next = block.nextElementSibling;
      block.remove();
      while (next && next.tagName !== "H3") {
        const current = next;
        next = next.nextElementSibling;
        current.remove();
      }
      renumberSections(activeTemplate.dataset.template);
    } else {
      block.remove();
    }

    saveActiveBody("Bloco removido");
  };

  const decorateBlocks = (body) => {
    if (!body) return;
    body.querySelectorAll(".block-delete").forEach((button) => button.remove());
    body.querySelectorAll(":scope > p, :scope > h3, :scope > ol").forEach((block) => {
      if (!block.dataset.blockSelectable) {
        block.dataset.blockSelectable = "true";
        block.addEventListener("click", () => {
          document.querySelectorAll(".is-selected-block").forEach((selected) => selected.classList.remove("is-selected-block"));
          block.classList.add("is-selected-block");
        });
      }

      const button = document.createElement("button");
      button.type = "button";
      button.className = "block-delete";
      button.setAttribute("aria-label", "Excluir bloco");
      button.textContent = "Excluir";
      button.addEventListener("click", (event) => {
        event.preventDefault();
        event.stopPropagation();
        removeBlock(block);
      });
      block.append(button);
    });
  };

  const hydrateTemplateBodies = () => {
    templates.forEach((template) => {
      const body = template.querySelector(".document-body");
      const saved = window.localStorage.getItem(bodyKey(template));
      if (body && saved) body.innerHTML = saved;
      normalizeTemplateSections(template);
      body?.querySelectorAll("[data-editable-id]").forEach(bindEditable);
      decorateBlocks(body);
    });
    document.querySelectorAll("[data-editable-id]").forEach(bindEditable);
  };

  const reviewPendingFields = () => {
    const templateName = getActiveTemplate()?.dataset.template;
    const firstPending = (essentialFields[templateName] || []).find(({ id }) => !getFieldDisplayValue(getFieldById(id)));
    if (!firstPending) {
      setStatus("Campos essenciais completos");
      return;
    }
    const control = document.querySelector(panelFieldSelector(firstPending.id));
    control?.focus();
    setStatus("Revisando pendências");
  };

  choices.forEach((choice) => {
    choice.addEventListener("click", () => {
      setTemplate(choice.dataset.templateTarget);
      setStatus(`Modelo ativo: ${choice.querySelector("span")?.textContent || "documento"}`);
    });
  });

  printButton?.addEventListener("click", () => {
    const templateName = getActiveTemplate()?.dataset.template;
    const pending = (essentialFields[templateName] || []).filter(({ id }) => !getFieldDisplayValue(getFieldById(id)));
    if (pending.length > 0) {
      setStatus(`Há ${pending.length} pendência${pending.length > 1 ? "s" : ""} antes da exportação`);
      reviewPendingFields();
      return;
    }
    setStatus("Visualização pronta para exportação em PDF");
    window.print();
  });

  reviewButton?.addEventListener("click", () => {
    reviewPendingFields();
  });

  undoButton?.addEventListener("click", () => {
    undoLastChange();
  });

  document.addEventListener("keydown", (event) => {
    if (!(event.ctrlKey || event.metaKey) || event.key.toLowerCase() !== "z") return;
    event.preventDefault();
    undoLastChange();
  });

  insertButtons.forEach((button) => {
    button.addEventListener("click", () => {
      insertBlock(button.dataset.insertBlock);
      closeInsertMenu();
    });
  });

  openInsertMenuButton?.addEventListener("click", (event) => {
    event.stopPropagation();
    toggleInsertMenu();
  });

  resetButton?.addEventListener("click", () => {
    const activeTemplate = getActiveTemplate();
    if (!activeTemplate) return;
    const label = getTemplateLabel(activeTemplate.dataset.template);
    const confirmed = window.confirm(`Limpar o rascunho de ${label}? Esta ação remove os dados salvos deste navegador.`);
    if (!confirmed) return;

    activeTemplate.querySelectorAll("[data-editable-id]").forEach((field) => {
      window.localStorage.removeItem(fieldKey(field));
      field.innerHTML = field.dataset.placeholder || field.textContent || "";
    });
    window.localStorage.removeItem(bodyKey(activeTemplate));
    window.location.reload();
  });

  document.addEventListener("pointerdown", (event) => {
    const target = event.target;
    const activeEditable = document.querySelector(activeEditableSelector);
    const activePanelField = document.activeElement instanceof HTMLElement && document.activeElement.matches(panelFieldActiveSelector)
      ? document.activeElement
      : null;
    const clickedEditableField = target instanceof Element && Boolean(target.closest(".editable-field"));
    const clickedPanelField = target instanceof Element && Boolean(target.closest(panelFieldActiveSelector));
    const clickedInsideDocument = target instanceof Element && Boolean(target.closest(".legal-page"));
    const clickedAllowedDocumentControl = target instanceof Element && Boolean(target.closest(".block-delete"));

    if (
      clickedInsideDocument &&
      !clickedEditableField &&
      !clickedAllowedDocumentControl
    ) {
      if (activeEditable instanceof HTMLElement) activeEditable.blur();
      if (activePanelField) activePanelField.blur();
      lastFocusedEditable = null;
      clearDocumentSelectionState();
      event.preventDefault();
      window.getSelection()?.removeAllRanges();
      return;
    }

    if (activeEditable instanceof HTMLElement) {
      const clickedInsideEditable = target instanceof Node && activeEditable.contains(target);
      if (!clickedInsideEditable && !clickedEditableField && !clickedPanelField) {
        activeEditable.blur();
        lastFocusedEditable = null;
      }
    }

    if (activePanelField && !clickedPanelField && !clickedEditableField) {
      activePanelField.blur();
    }

    if (
      insertMenu &&
      !insertMenu.hidden &&
      target instanceof Element &&
      !target.closest("[data-insert-menu]") &&
      !target.closest("[data-open-insert-menu]")
    ) {
      closeInsertMenu();
    }
  });

  hydrateTemplateBodies();
  setTemplate(window.localStorage.getItem(`${storagePrefix}active`) || "peticao");
  updateUndoButton();
  setStatus("Preencha os campos principais para montar o documento", "Rascunho salvo neste navegador");
</script>
