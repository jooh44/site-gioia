---
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Editor de Templates Jurídicos | Gioia e Associados";
const description = "Editor interno de documentos jurídicos da Gioia e Associados.";
---

<BaseLayout title={title} description={description} canonical="https://gioiaeassociados.com.br/templates" robots="noindex, nofollow">
  <main class="template-app" data-template-app>
    <aside class="template-sidebar" aria-label="Controles do editor">
      <a class="back-link" href="/">Gioia e Associados</a>

      <div>
        <p class="sidebar-kicker">Editor interno</p>
        <h1>Templates jurídicos</h1>
        <p class="sidebar-text">
          Preencha os campos principais, ajuste a estrutura do documento e exporte em PDF quando terminar.
        </p>
      </div>

      <div class="quick-guide" aria-label="Passos de uso">
        <span>1. Escolha o modelo</span>
        <span>2. Preencha os campos essenciais</span>
        <span>3. Revise e exporte em PDF</span>
      </div>

      <div class="editor-status" data-editor-status aria-live="polite">Pronto para editar</div>

      <div class="control-group" aria-label="Selecionar modelo">
        <button class="template-choice is-active" type="button" data-template-target="peticao">
          <span>Petição inicial</span>
          <small>Saúde, cível e urgência</small>
        </button>
        <button class="template-choice" type="button" data-template-target="procuracao">
          <span>Procuração</span>
          <small>Ad judicia et extra</small>
        </button>
        <button class="template-choice" type="button" data-template-target="contrato">
          <span>Contrato</span>
          <small>Honorários advocatícios</small>
        </button>
      </div>

      <div class="action-row">
        <button class="secondary-action" type="button" data-undo-change disabled>Desfazer</button>
      </div>

      <div class="insert-group" aria-label="Estrutura do documento">
        <div class="section-heading">
          <p>Estrutura do documento</p>
          <button class="add-fab" type="button" data-open-insert-menu aria-expanded="false" aria-controls="insert-menu">+</button>
        </div>
        <div class="insert-menu" data-insert-menu id="insert-menu" hidden>
          <button class="insert-action" type="button" data-insert-block="section">Adicionar seção</button>
          <button class="insert-action" type="button" data-insert-block="paragraph">Adicionar parágrafo</button>
          <button class="insert-action" type="button" data-insert-block="list-item">Adicionar item de lista</button>
          <button class="insert-action" type="button" data-insert-block="field">Adicionar campo livre</button>
        </div>
      </div>

      <section class="summary-group" aria-label="Resumo do rascunho">
        <p>Resumo do rascunho</p>
        <div class="summary-card">
          <strong data-progress-count>0 de 0 campos preenchidos</strong>
          <span data-progress-pending>Nenhuma pendência no momento</span>
        </div>
      </section>

      <section class="fields-group" aria-label="Campos essenciais">
        <div class="section-heading">
          <p>Campos essenciais</p>
          <button class="ghost-action" type="button" data-review-pending>Revisar pendências</button>
        </div>
        <div class="field-list" data-field-list></div>
      </section>

      <div class="action-row export-row">
        <button class="primary-action" type="button" data-print-document>Exportar PDF</button>
      </div>

      <div class="danger-group" aria-label="Ações destrutivas">
        <p>Ações destrutivas</p>
        <button class="danger-action" type="button" data-reset-template>Limpar modelo</button>
      </div>

      <p class="sidebar-note">
        Os dados ficam salvos apenas neste navegador. Seções novas são numeradas automaticamente conforme a lógica do modelo ativo.
      </p>
    </aside>

    <section class="workspace" aria-label="Documento editável">
      <div class="paper-scale">
        <article class="legal-page is-active" data-template="peticao" aria-label="Template de petição inicial">
          <img class="watermark watermark-left" src="/brand/assets/watermark-left-figma.svg" alt="" aria-hidden="true" />
          <img class="watermark watermark-right" src="/brand/assets/watermark-right-figma.svg" alt="" aria-hidden="true" />
          <header class="brand-header">
            <img class="brand-logo" src="/brand/assets/logo-gioia-versao-garnet.svg" alt="Gioia e Associados Advocacia" />
          </header>

          <section class="court-line">
            EXCELENTÍSSIMO SENHOR DOUTOR JUIZ DE DIREITO DA
            <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-vara">[VARA / FORO / COMARCA / ESTADO]</span>
          </section>

          <div class="badges">
            <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-prioridade">PRIORIDADE</span>
            <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-segredo">SEGREDO DE JUSTIÇA</span>
            <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-urgencia">TUTELA DE URGÊNCIA</span>
          </div>

          <header class="document-title">
            <h2>PETIÇÃO INICIAL</h2>
            <p>Processo nº <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-processo">[NÚMERO DO PROCESSO, SE JÁ EXISTIR]</span></p>
          </header>

          <div class="document-body">
            <p>
              <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-autora">[NOME DA PARTE AUTORA]</span>, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-qualificacao">[QUALIFICAÇÃO COMPLETA]</span>, neste ato <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-representacao">[EM NOME PRÓPRIO / REPRESENTADA POR]</span>, por seus advogados infra-assinados, com escritório profissional na <strong>Gioia e Associados Advocacia</strong>, onde recebem intimações e notificações de estilo, vem, com o devido respeito, à presença de Vossa Excelência propor a presente:
            </p>

            <h3><span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-acao">[NOME DA AÇÃO]</span></h3>

            <p>
              em face de <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-re">[NOME DA PARTE RÉ]</span>, inscrita no <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-documento-re">[CPF/CNPJ]</span>, com sede/endereço em <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-endereco-re">[ENDEREÇO COMPLETO]</span>, pelos fatos e fundamentos jurídicos a seguir expostos.
            </p>

            <h3>I. Síntese Fática</h3>
            <p><span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-fatos">[RESUMO CLARO DO CONTEXTO FÁTICO. Descrever origem do problema, tentativas extrajudiciais, documentos anexados e impacto concreto para a parte autora.]</span></p>

            <h3>II. Da Prioridade / Tutela de Urgência</h3>
            <p><span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-tutela">[FUNDAMENTOS DA PRIORIDADE OU TUTELA: idade avançada, doença grave, risco iminente, necessidade de home care, negativa de cobertura ou verba alimentar.]</span></p>

            <h3>III. Do Direito</h3>
            <p><span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-direito">[BASE LEGAL, JURISPRUDÊNCIA E PRINCÍPIOS APLICÁVEIS. Demonstrar probabilidade do direito e perigo de dano, quando cabível.]</span></p>

            <h3>IV. Dos Pedidos</h3>
            <ol>
              <li>O recebimento da presente petição inicial, com a regular citação da parte ré.</li>
              <li>O deferimento de <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-pedido-urgencia">[TUTELA DE URGÊNCIA / PRIORIDADE / MEDIDA LIMINAR]</span>, nos termos da fundamentação exposta.</li>
              <li>A procedência integral da ação, para condenar a parte ré a <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-obrigacao">[OBRIGAÇÃO PRETENDIDA]</span>.</li>
              <li>A condenação da parte ré ao pagamento das verbas sucumbenciais e demais cominações legais.</li>
              <li>A produção de todas as provas admitidas em direito, em especial <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-provas">[DOCUMENTAL / TESTEMUNHAL / PERICIAL]</span>.</li>
            </ol>

            <p>Dá-se à causa o valor de <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-valor">[VALOR DA CAUSA]</span>, para fins legais.</p>
            <p>Termos em que,<br />pede deferimento.</p>
            <p>São Paulo, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="peticao-data">[DATA POR EXTENSO]</span>.</p>
          </div>

          <section class="signature-grid">
            <div class="signature-block">
              <span></span>
              <strong>CELSO FERNANDO GIOIA</strong>
              <small>OAB/SP 70.379</small>
            </div>
            <div class="signature-block">
              <span></span>
              <strong>MARIANA MATHEUS GIOIA</strong>
              <small>OAB/SP 351.962</small>
            </div>
          </section>

          <footer class="office-footer">
            <strong>Gioia e Associados Advocacia</strong>
            <span>Rua Barão de Jundiaí, 523, Alto da Lapa, São Paulo - SP, CEP 05073-010</span>
            <span>(11) 3835-3200 · (11) 9 9334-9907 · contato@gioiaeassociados.com.br</span>
          </footer>
        </article>

        <article class="legal-page" data-template="procuracao" aria-label="Template de procuração">
          <img class="watermark watermark-left" src="/brand/assets/watermark-left-figma.svg" alt="" aria-hidden="true" />
          <img class="watermark watermark-right" src="/brand/assets/watermark-right-figma.svg" alt="" aria-hidden="true" />
          <header class="brand-header">
            <img class="brand-logo" src="/brand/assets/logo-gioia-versao-garnet.svg" alt="Gioia e Associados Advocacia" />
          </header>

          <header class="document-title compact">
            <h2>PROCURAÇÃO AD JUDICIA ET EXTRA</h2>
            <p>Uso recomendado para outorga de poderes processuais</p>
          </header>

          <div class="document-body">
            <p>
              Pelo presente instrumento particular, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-outorgante">[NOME COMPLETO DO OUTORGANTE]</span>, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-qualificacao">[NACIONALIDADE, ESTADO CIVIL, PROFISSÃO]</span>, portador(a) do RG nº <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-rg">[RG]</span> e inscrito(a) no CPF nº <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-cpf">[CPF]</span>, e-mail <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-email">[E-MAIL]</span>, residente e domiciliado(a) em <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-endereco">[ENDEREÇO COMPLETO]</span>, nomeia e constitui como seus procuradores os advogados integrantes de <strong>Gioia e Associados Advocacia</strong>.
            </p>

            <p>
              Ficam nomeados, em especial, <strong>CELSO FERNANDO GIOIA</strong>, OAB/SP 70.379, <strong>MARIANA MATHEUS GIOIA</strong>, OAB/SP 351.962, e <strong>FÁBIO DREGER DA SILVA</strong>, OAB/SP 336.451, todos com escritório profissional na Rua Barão de Jundiaí, nº 523, Alto da Lapa, São Paulo/SP, CEP 05073-010, e-mail <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-email-escritorio">[E-MAIL DO ESCRITÓRIO OU RESPONSÁVEL]</span>.
            </p>

            <p>
              Outorga-lhes amplos poderes para o foro em geral, com a cláusula <em>ad judicia et extra</em>, para representar o(a) outorgante em qualquer Juízo, Instância ou Tribunal, podendo propor ações, contestar, reconvir, apresentar pedido contraposto, firmar compromissos, receber e dar quitação, transigir, desistir, recorrer, substabelecer, requerer documentos, participar de audiências e praticar todos os demais atos necessários ao fiel desempenho deste mandato.
            </p>

            <p>Referência específica do caso: <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-referencia">[NÚMERO DO PROCESSO / OBJETO / PARTE ADVERSA / ÓRGÃO]</span>.</p>
            <p>Esta procuração é firmada para a defesa integral dos interesses do(a) outorgante no caso acima descrito, inclusive perante repartições públicas, autarquias, cartórios, órgãos administrativos e instituições privadas relacionadas ao objeto da demanda.</p>
            <p>São Paulo, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="proc-data">[DATA POR EXTENSO]</span>.</p>
          </div>

          <section class="signature-grid single">
            <div class="signature-block">
              <span></span>
              <strong>[NOME COMPLETO DO OUTORGANTE]</strong>
              <small>CPF nº [CPF]</small>
            </div>
          </section>

          <footer class="office-footer">
            <strong>Gioia e Associados Advocacia</strong>
            <span>Rua Barão de Jundiaí, 523, Alto da Lapa, São Paulo - SP, CEP 05073-010</span>
            <span>(11) 3835-3200 · (11) 9 9334-9907 · contato@gioiaeassociados.com.br</span>
          </footer>
        </article>

        <article class="legal-page" data-template="contrato" aria-label="Template de contrato de honorários">
          <img class="watermark watermark-left" src="/brand/assets/watermark-left-figma.svg" alt="" aria-hidden="true" />
          <img class="watermark watermark-right" src="/brand/assets/watermark-right-figma.svg" alt="" aria-hidden="true" />
          <header class="brand-header">
            <img class="brand-logo" src="/brand/assets/logo-gioia-versao-garnet.svg" alt="Gioia e Associados Advocacia" />
          </header>

          <header class="document-title compact">
            <h2>CONTRATO PARTICULAR DE PRESTAÇÃO DE SERVIÇOS DE ADVOCACIA</h2>
          </header>

          <div class="document-body">
            <p>
              Por este instrumento particular, as partes ao final assinadas, de um lado, como <strong>CONTRATANTE</strong>, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-cliente">[NOME COMPLETO DO CLIENTE]</span>, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-qualificacao">[QUALIFICAÇÃO COMPLETA]</span>, residente e domiciliado(a) em <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-endereco">[ENDEREÇO COMPLETO]</span>, e, de outro lado, como <strong>CONTRATADA</strong>, <strong>GIOIA E ASSOCIADOS ADVOCACIA</strong>, com sede na Rua Barão de Jundiaí, nº 523, Alto da Lapa, São Paulo/SP, CEP 05073-010, inscrita na OAB/SP sob nº 2.254 e no CNPJ sob nº 69.108.108/0001-07, neste ato representada por seu sócio-titular, <strong>Celso Fernando Gioia</strong>, têm entre si justo e contratado o seguinte.
            </p>

            <h3>Cláusula Primeira — Objeto</h3>
            <p>A CONTRATADA obriga-se a prestar ao(à) CONTRATANTE serviços advocatícios consistentes em <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-objeto">[DESCREVER A DEMANDA: AÇÃO, DEFESA, RECURSO, CUMPRIMENTO DE SENTENÇA, ETC.]</span>, perante <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-foro">[FORO / VARA / TRIBUNAL / ÓRGÃO]</span>, em face de <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-parte-adversa">[PARTE ADVERSA]</span>.</p>

            <h3>Cláusula Segunda — Honorários</h3>
            <p>Em contraprestação pelos serviços ora ajustados, o(a) CONTRATANTE pagará à CONTRATADA honorários advocatícios no valor de <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-honorarios">[VALOR FIXO / PERCENTUAL / MODELO HÍBRIDO]</span>.</p>
            <p>Quando houver cláusula quota litis, registrar de forma objetiva: <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-quota">[PERCENTUAL SOBRE ACORDO / ALVARÁ / INDENIZAÇÃO / FGTS / VERBAS RESCISÓRIAS / OUTROS DIREITOS]</span>.</p>

            <h3>Cláusula Terceira — Despesas e Custas</h3>
            <p>As despesas processuais, custas, diligências, cópias, autenticações, taxas, emolumentos, deslocamentos e demais desembolsos necessários à condução da demanda serão de responsabilidade do(a) CONTRATANTE, mediante prévio adiantamento ou posterior reembolso, conforme alinhamento entre as partes.</p>

            <h3>Cláusula Quarta — Obrigações das Partes</h3>
            <p>Compete ao(à) CONTRATANTE fornecer documentos, informações verdadeiras e subsídios necessários ao regular patrocínio da causa. Compete à CONTRATADA atuar com zelo técnico, observando a legislação aplicável e o Estatuto da Advocacia, sem garantia de resultado, por se tratar de obrigação de meio.</p>

            <h3>Cláusula Quinta — Rescisão</h3>
            <p>Em caso de revogação de mandato, renúncia, acordo direto, desistência, inadimplemento ou encerramento antecipado da contratação, aplicar-se-á o que estiver definido em <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-rescisao">[CLÁUSULA ESPECÍFICA DE RESCISÃO / HONORÁRIOS PROPORCIONAIS / TABELA OAB]</span>.</p>

            <p>E, por estarem de acordo, firmam o presente instrumento em duas vias de igual teor e forma, para que produza seus efeitos legais.</p>
            <p>São Paulo, <span class="editable-field" contenteditable="true" spellcheck="true" data-editable-id="contrato-data">[DATA POR EXTENSO]</span>.</p>
          </div>

          <section class="signature-grid">
            <div class="signature-block">
              <span></span>
              <strong>[NOME DO(A) CONTRATANTE]</strong>
              <small>Contratante</small>
            </div>
            <div class="signature-block">
              <span></span>
              <strong>CELSO FERNANDO GIOIA</strong>
              <small>Contratada</small>
            </div>
          </section>
          <section class="signature-grid">
            <div class="signature-block">
              <span></span>
              <strong>[TESTEMUNHA 1]</strong>
              <small>RG: [RG]</small>
            </div>
            <div class="signature-block">
              <span></span>
              <strong>[TESTEMUNHA 2]</strong>
              <small>RG: [RG]</small>
            </div>
          </section>

          <footer class="office-footer">
            <strong>Gioia e Associados Advocacia</strong>
            <span>Rua Barão de Jundiaí, 523, Alto da Lapa, São Paulo - SP, CEP 05073-010</span>
            <span>(11) 3835-3200 · (11) 9 9334-9907 · contato@gioiaeassociados.com.br</span>
          </footer>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #e7e1d8;
  }

  :global(a[aria-label="Falar com a Gioia e Associados no WhatsApp"]) {
    display: none !important;
  }

  .template-app {
    --garnet: #5e0001;
    --garnet-soft: #7a0b0d;
    --gold: #bf9f5b;
    --paper: #fffdf8;
    --ink: #201c19;
    --muted: #74695f;
    min-height: 100dvh;
    display: grid;
    grid-template-columns: 340px minmax(0, 1fr);
    color: var(--ink);
    background:
      linear-gradient(90deg, rgba(94, 0, 1, 0.04), transparent 36%),
      #e7e1d8;
  }

  .template-sidebar {
    position: sticky;
    top: 0;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    gap: 18px;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 24px 26px 30px;
    border-right: 1px solid rgba(94, 0, 1, 0.14);
    background: #fffaf2;
  }

  .back-link {
    width: fit-content;
    color: var(--garnet);
    font-family: var(--font-serif);
    font-size: 18px;
    text-decoration: none;
  }

  .sidebar-kicker {
    margin: 0 0 8px;
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .template-sidebar h1 {
    margin: 0;
    color: var(--garnet);
    font-family: var(--font-serif);
    font-size: 31px;
    line-height: 1;
    letter-spacing: 0;
  }

  .sidebar-text,
  .sidebar-note {
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }

  .quick-guide {
    display: grid;
    gap: 5px;
    padding: 10px 12px;
    border: 1px solid rgba(94, 0, 1, 0.12);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.58);
    color: var(--muted);
    font-size: 12px;
  }

  .quick-guide span {
    display: flex;
    align-items: center;
    min-height: 20px;
  }

  .editor-status {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(191, 159, 91, 0.32);
    border-radius: 0;
    background: rgba(191, 159, 91, 0.10);
    color: var(--garnet);
    font-size: 12px;
    font-weight: 700;
  }

  .sidebar-note {
    margin-top: 0;
    padding-top: 14px;
    border-top: 1px solid rgba(94, 0, 1, 0.12);
    font-size: 12px;
  }

  .control-group,
  .action-row,
  .insert-group,
  .summary-group,
  .fields-group,
  .danger-group {
    display: grid;
    gap: 10px;
  }

  .template-choice,
  .primary-action,
  .secondary-action,
  .insert-action,
  .ghost-action,
  .danger-action {
    min-height: 46px;
    border: 1px solid rgba(94, 0, 1, 0.16);
    border-radius: 0;
    font: inherit;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease, color 180ms ease;
  }

  .template-choice {
    display: grid;
    gap: 2px;
    padding: 13px 14px;
    text-align: left;
    background: rgba(255, 255, 255, 0.68);
    color: var(--ink);
  }

  .template-choice span {
    font-size: 14px;
    font-weight: 700;
  }

  .template-choice small {
    color: var(--muted);
    font-size: 12px;
  }

  .template-choice.is-active {
    border-color: var(--garnet);
